# Firebase web app config. Copy this file to ".env.local" and fill in the values
# from Firebase Console > Project settings > Your apps > SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- AI features (optional) ---
# Base URL of the LLM proxy. The client calls `${VITE_AI_PROXY_URL}/designProblem`
# and `${VITE_AI_PROXY_URL}/generateWidget`. When unset, AI features fall back to
# the built-in deterministic generator (no key needed).
#
# Production (Vercel serverless functions, same-origin — recommended):
#   VITE_AI_PROXY_URL=/api
# Production (frontend hosted separately from the Vercel API):
#   VITE_AI_PROXY_URL=https://<your-app>.vercel.app/api
# Local dev with the Firebase Functions emulator (legacy backend):
#   VITE_AI_PROXY_URL=http://127.0.0.1:5001/brilliant-alpha-clone-58c31/us-central1
# Local dev with `vercel dev`:
#   VITE_AI_PROXY_URL=http://localhost:3000/api
VITE_AI_PROXY_URL=
