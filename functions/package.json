{
  "name": "functions",
  "description": "Serverless LLM proxy for the geometry app (holds the OpenAI key).",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
